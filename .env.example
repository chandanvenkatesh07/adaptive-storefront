# Optional. Without it, the demo runs on cached fallback specs (still fully works).
# With it, the "Generate live" path calls the model for a fresh layout.
OPENAI_API_KEY=sk-...

# Optional. Defaults to gpt-5.4-mini for lower-cost live demos.
# Use gpt-5.5 when you want the strongest live-generation quality.
OPENAI_MODEL=gpt-5.4-mini
